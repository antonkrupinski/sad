{
  "manifest_version": 3,
  "name": "Persistent DevTools Edits",
  "version": "1.0",
  "permissions": [
    "storage",
    "scripting",
    "webNavigation"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
