{
  "manifest_version": 3,
  "name": "Grade Changer",
  "version": "1.0",
  "description": "Change your grades on Canvas for fun.",
  "permissions": [
    "scripting",
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://canvas.yourschool.edu/*"],  // Change to your Canvas URL
      "js": ["content.js"]
    }
  ]
}
